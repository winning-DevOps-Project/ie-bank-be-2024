{
  "info": {
    "name": "IE Bank API Tests",
    "description": "Postman tests for the IE Bank API endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Home",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/",
        "description": "Check if the backend is running."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response contains Welcome message', function () {",
              "    pm.response.text().includes('Welcome to IE Bank Backend!');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Register User",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/register/",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"test_user\",\n    \"password\": \"Password123\",\n    \"password_2\": \"Password123\",\n    \"country\": \"US\"\n}"
        },
        "description": "Register a new user."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test('Response contains access token', function () {",
              "    pm.response.json().hasOwnProperty('access_token');",
              "});",
              "pm.environment.set('access_token', pm.response.json().access_token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Account",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/accounts/",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Savings Account\",\n    \"currency\": \"USD\",\n    \"country\": \"US\"\n}"
        },
        "description": "Create an account for the logged-in user."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 403', function () {",
              "    pm.response.to.have.status(403);",
              "});",
              "pm.test('Response contains admin access required message', function () {",
              "    pm.response.json().msg === 'Admin access required';",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Transfer Money",
      "request": {
        "method": "POST",
        "url": "{{base_url}}/transfer/",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"sender_account_number\": \"123456\",\n    \"recipient_account_number\": \"654321\",\n    \"amount\": 50\n}"
        },
        "description": "Transfer money between accounts."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "pm.test('Response contains account not found message', function () {",
              "    const jsonResponse = pm.response.json();",
              "    pm.expect(jsonResponse.msg).to.match(/Sender account not found|Recipient account not found/);",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "access_token",
      "value": ""
    }
  ]
}

